PUBLIC_SANITY_PROJECT_ID="wfdg37xd"
PUBLIC_SANITY_DATASET="production"

# Optional: controls which Sanity perspective the site uses for normal page
# content. Defaults to drafts locally, drafts on the Cloudflare staging branch,
# and published everywhere else.
# SANITY_CONTENT_PERSPECTIVE="published"

# Optional: use these if the Studio/project differs by environment.
# PUBLIC_SANITY_STUDIO_PROJECT_ID=""
# PUBLIC_SANITY_STUDIO_DATASET=""

# Optional: required for deployed draft/staging content reads and other
# authenticated Sanity API operations.
# SANITY_API_READ_TOKEN=""
# SANITY_API_TOKEN=""

# Optional: fills missing CMS image slots with deterministic Sanity fixture
# images. Existing uploaded CMS images are still used first.
# PUBLIC_USE_LOCAL_SANITY_FIXTURES=false
