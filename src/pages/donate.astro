---
const donateUrl = "/?give=8NDR96EK";
const giveId = "8NDR96EK";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>Redirecting to Donate | Dallas Bike Coalition</title>
    <meta http-equiv="refresh" content={`0;url=${donateUrl}`} />
    <link rel="canonical" href={donateUrl} />
  </head>
  <body>
    <p>
      Redirecting to the donation page.
      <a href={donateUrl}>Continue if you are not redirected automatically.</a>
    </p>
    <script is:inline define:vars={{ giveId }}>
      if (typeof window !== "undefined") {
        let targetUrl = new URL("/", window.location.origin);

        if (document.referrer) {
          const referrerUrl = new URL(document.referrer);
          const donateUrl = new URL("/donate", window.location.origin);

          if (
            referrerUrl.origin === window.location.origin &&
            referrerUrl.pathname !== donateUrl.pathname
          ) {
            targetUrl = referrerUrl;
          }
        }

        targetUrl.searchParams.set("give", giveId);
        window.location.replace(targetUrl.toString());
      }
    </script>
  </body>
</html>
