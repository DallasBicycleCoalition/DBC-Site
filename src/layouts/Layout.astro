---
import { ClientRouter } from "astro:transitions";
import DisableDraftMode from "../components/DisableDraftMode";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import SanityVisualEditing from "../components/SanityVisualEditing";
import "../globals.css";

const {
  title = "Dallas Bike Coalition",
  description = "Dallas Bike Coalition advocates for safe, connected, and accessible bicycling in Dallas.",
  draftMode = false,
} = Astro.props;

const pageTitle =
  title === "Dallas Bike Coalition"
    ? title
    : `${title} | Dallas Bike Coalition`;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />

    <title>{pageTitle}</title>
    <ClientRouter />
    <script
      is:inline
      src="https://dallas-bicycle-coalition.givecloud.co/v1/widgets.js"
      async></script>
  </head>
  <body>
    <a class="skip-link" href="#main-content">Skip to main content</a>
    <Header />
    <main id="main-content">
      <slot />
    </main>
    <Footer />
    {
      draftMode && (
        <>
          <SanityVisualEditing client:only="react" />
          <DisableDraftMode client:only="react" />
        </>
      )
    }
  </body>
</html>
