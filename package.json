{
  "name": "dbc-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && tsc --noEmit && astro build",
    "preview": "astro preview",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "prettify": "prettier --write .",
    "typegen": "SANITY_SCHEMA_EXTRACT=true npx sanity schema extract && sanity typegen generate",
    "devt": "SANITY_SCHEMA_EXTRACT=true npx sanity schema extract && sanity typegen generate && astro dev",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.8",
    "@astrojs/cloudflare": "^13.1.10",
    "@astrojs/react": "^4.4.2",
    "@fullcalendar/core": "^6.1.20",
    "@fullcalendar/daygrid": "^6.1.20",
    "@fullcalendar/list": "^6.1.20",
    "@fullcalendar/react": "^6.1.20",
    "@fullcalendar/rrule": "^6.1.20",
    "@fullcalendar/timegrid": "^6.1.20",
    "@portabletext/react": "^6.0.3",
    "@sanity/astro": "^3.3.1",
    "@sanity/image-url": "^2.1.1",
    "@sanity/preview-url-secret": "4.0.4",
    "@sanity/vision": "5.19.0",
    "@sanity/visual-editing": "5.3.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "astro": "^6.2.2",
    "autoprefixer": "10.4.27",
    "groq": "5.19.0",
    "prettier-plugin-astro": "0.14.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "rrule": "^2.8.1",
    "sanity": "^5.19.0",
    "sanity-plugin-recurring-dates": "^2.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "eslint": "^9.39.4",
    "prettier": "3.8.1",
    "typescript": "^5.9.3",
    "vite": "^8.0.10"
  },
  "engines": {
    "node": ">= 20.18"
  },
  "overrides": {
    "@asamuzakjp/css-color": "4.1.2",
    "@asamuzakjp/dom-selector": "6.8.1"
  }
}
