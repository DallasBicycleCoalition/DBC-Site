{
  "name": "dbc-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "start": "astro dev",
    "build": "astro check && tsc --noEmit && astro build",
    "preview": "astro preview",
    "deploy": "wrangler deploy -c dist/server/wrangler.json",
    "lint": "eslint .",
    "format:check": "prettier --check .",
    "prettify": "prettier --write .",
    "typegen": "SANITY_SCHEMA_EXTRACT=true npx sanity schema extract && sanity typegen generate",
    "devt": "SANITY_SCHEMA_EXTRACT=true npx sanity schema extract && sanity typegen generate && astro dev",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/check": "^0.9.9",
    "@astrojs/cloudflare": "^14.1.1",
    "@astrojs/react": "^6.0.1",
    "@fullcalendar/core": "^6.1.21",
    "@fullcalendar/daygrid": "^6.1.21",
    "@fullcalendar/list": "^6.1.21",
    "@fullcalendar/react": "^6.1.21",
    "@fullcalendar/rrule": "^6.1.21",
    "@fullcalendar/timegrid": "^6.1.21",
    "@portabletext/react": "^6.2.0",
    "@sanity/astro": "^3.4.2",
    "@sanity/icons": "^5.0.0",
    "@sanity/image-url": "^2.1.1",
    "@sanity/preview-url-secret": "^4.0.8",
    "@sanity/ui": "^3.3.1",
    "@sanity/util": "^6.3.0",
    "@sanity/vision": "^6.3.0",
    "@sanity/visual-editing": "^5.4.5",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "astro": "^7.0.6",
    "autoprefixer": "10.5.2",
    "groq": "^6.3.0",
    "prettier-plugin-astro": "0.14.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "rrule": "^2.8.1",
    "sanity": "^6.3.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@types/node": "^25.9.4",
    "eslint": "^9.39.4",
    "prettier": "3.9.4",
    "typescript": "^5.9.3",
    "vite": "^8.1.3",
    "wrangler": "^4.107.0"
  },
  "engines": {
    "node": ">= 22.13.0"
  },
  "overrides": {
    "@asamuzakjp/css-color": "4.1.2",
    "@asamuzakjp/dom-selector": "6.8.1"
  }
}
