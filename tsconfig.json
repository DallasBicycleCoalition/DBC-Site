{
  "compilerOptions": {
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "importsNotUsedAsValues": "remove",
    "isolatedModules": true,
    "jsx": "preserve",
    "lib": ["dom", "dom.iterable", "esnext"],
    "module": "esnext",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2022"
  },
  "extends": "astro/tsconfigs/strict",
  "exclude": ["node_modules", "dist", "*.mjs", "*.cjs"],
  "include": [
    ".astro/types.d.ts",
    "src/env.d.ts",
    "src/**/*",
    "lib/**/*",
    "schema/**/*",
    "types/**/*.d.ts",
    "sanity.config.ts"
  ]
}
